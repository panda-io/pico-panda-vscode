{
    "val declaration": {
        "prefix": "val",
        "body": ["val ${1:name}: ${2:int} = ${3:value}"],
        "description": "Immutable variable declaration"
    },

    "var declaration": {
        "prefix": "var",
        "body": ["var ${1:name}: ${2:int} = ${3:value}"],
        "description": "Mutable variable declaration"
    },

    "const declaration": {
        "prefix": "const",
        "body": ["const ${1:NAME}: ${2:int} = ${3:value}"],
        "description": "Constant declaration"
    },

    "function": {
        "prefix": "fun",
        "body": [
            "fun ${1:name}(${2:params})",
            "\t${0}"
        ],
        "description": "Function declaration"
    },

    "function with return": {
        "prefix": "funr",
        "body": [
            "fun ${1:name}(${2:params}) ${3:int}",
            "\treturn ${0}"
        ],
        "description": "Function declaration with return type"
    },

    "signal handler": {
        "prefix": "signal",
        "body": [
            "@signal(${1:SIGNAL_APP_START})",
            "fun ${2:on_start}()",
            "\t${0}"
        ],
        "description": "Signal handler function"
    },

    "interval handler": {
        "prefix": "interval",
        "body": [
            "@interval(${1:SIGNAL_TICK}, ${2:100})",
            "fun ${3:on_timer}()",
            "\t${0}"
        ],
        "description": "Interval timer handler"
    },

    "if": {
        "prefix": "if",
        "body": [
            "if ${1:condition}",
            "\t${0}"
        ],
        "description": "If statement"
    },

    "if/else": {
        "prefix": "ife",
        "body": [
            "if ${1:condition}",
            "\t${2}",
            "else",
            "\t${0}"
        ],
        "description": "If/else statement"
    },

    "for range": {
        "prefix": "for",
        "body": [
            "for ${1:i} in ${2:0}..${3:n}",
            "\t${0}"
        ],
        "description": "For range loop"
    },

    "while": {
        "prefix": "while",
        "body": [
            "while ${1:condition}",
            "\t${0}"
        ],
        "description": "While loop"
    },

    "match": {
        "prefix": "match",
        "body": [
            "match ${1:value}",
            "\t${2:Pattern1}",
            "\t\t${3}",
            "\t${4:Pattern2}",
            "\t\t${0}"
        ],
        "description": "Match statement"
    },

    "preprocessor if": {
        "prefix": "ppif",
        "body": [
            "#if ${1:FLAG}",
            "${2}",
            "#end"
        ],
        "description": "Conditional compilation block"
    }
}
